{
  "version": 2,
  "installCommand": "echo 'Skipping default install, using custom build script'",
  "buildCommand": "sh scripts/vercel-build.sh",
  "outputDirectory": "build/web",
  "rewrites": [
    {
      "source": "/(icons/.*|assets/.*|splash/.*|manifest.json|favicon.png|flutter_service_worker.js|main.dart.js|index.html)",
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}